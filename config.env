# RatOS Ubuntu installer configuration.
# Edit this file before running install.sh if you want different paths/branches.

RATOS_USER="${RATOS_USER:-pi}"
RATOS_PASSWORD="${RATOS_PASSWORD:-raspberry}"
RATOS_HOME="${RATOS_HOME:-/home/${RATOS_USER}}"

KLIPPER_REPO="${KLIPPER_REPO:-https://github.com/Klipper3d/klipper.git}"
KLIPPER_BRANCH="${KLIPPER_BRANCH:-master}"

MOONRAKER_REPO="${MOONRAKER_REPO:-https://github.com/Arksine/moonraker.git}"
MOONRAKER_BRANCH="${MOONRAKER_BRANCH:-master}"

RATOS_CONFIG_REPO="${RATOS_CONFIG_REPO:-https://github.com/Rat-OS/RatOS-configuration.git}"
RATOS_CONFIG_BRANCH="${RATOS_CONFIG_BRANCH:-v2.1.x}"
RATOS_THEME_REPO="${RATOS_THEME_REPO:-https://github.com/Rat-OS/RatOS-theme.git}"
RATOS_THEME_BRANCH="${RATOS_THEME_BRANCH:-v2.1.x}"
RATOS_CONFIGURATOR_REPO="${RATOS_CONFIGURATOR_REPO:-https://github.com/Rat-OS/RatOS-configurator.git}"
RATOS_CONFIGURATOR_BRANCH="${RATOS_CONFIGURATOR_BRANCH:-v2.1.x-deployment}"

MAINSAIL_URL="${MAINSAIL_URL:-https://github.com/mainsail-crew/mainsail/releases/latest/download/mainsail.zip}"
MAINSAIL_CONFIG_REPO="${MAINSAIL_CONFIG_REPO:-https://github.com/mainsail-crew/mainsail-config.git}"
MAINSAIL_CONFIG_BRANCH="${MAINSAIL_CONFIG_BRANCH:-master}"

CROWSNEST_REPO="${CROWSNEST_REPO:-https://github.com/mainsail-crew/crowsnest.git}"
CROWSNEST_BRANCH="${CROWSNEST_BRANCH:-master}"

TIMELAPSE_REPO="${TIMELAPSE_REPO:-https://github.com/mainsail-crew/moonraker-timelapse.git}"
TIMELAPSE_BRANCH="${TIMELAPSE_BRANCH:-main}"

LINEAR_MOVEMENT_ANALYSIS_REPO="${LINEAR_MOVEMENT_ANALYSIS_REPO:-https://github.com/worksasintended/klipper_linear_movement_analysis.git}"
LINEAR_MOVEMENT_ANALYSIS_BRANCH="${LINEAR_MOVEMENT_ANALYSIS_BRANCH:-main}"

KLIPPERSCREEN_REPO="${KLIPPERSCREEN_REPO:-https://github.com/jordanruthe/KlipperScreen.git}"
KLIPPERSCREEN_BRANCH="${KLIPPERSCREEN_BRANCH:-master}"

INSTALL_CROWSNEST="${INSTALL_CROWSNEST:-1}"
INSTALL_TIMELAPSE="${INSTALL_TIMELAPSE:-1}"
INSTALL_LINEAR_MOVEMENT_ANALYSIS="${INSTALL_LINEAR_MOVEMENT_ANALYSIS:-1}"
INSTALL_KLIPPERSCREEN="${INSTALL_KLIPPERSCREEN:-1}"
INSTALL_RPI_MCU="${INSTALL_RPI_MCU:-0}"
INSTALL_LATTEPANDA_IOTA_RP2040_MCU="${INSTALL_LATTEPANDA_IOTA_RP2040_MCU:-0}"
LATTEPANDA_IOTA_RP2040_FLASH_DEVICE="${LATTEPANDA_IOTA_RP2040_FLASH_DEVICE:-2e8a:0003}"

BASE_APT_DEPS="${BASE_APT_DEPS:-apt-transport-https avahi-daemon ca-certificates curl git gnupg sudo unzip wget}"

KLIPPER_APT_DEPS="${KLIPPER_APT_DEPS:-git virtualenv python3-dev python3-matplotlib libffi-dev build-essential libncurses-dev libusb-dev avrdude gcc-avr binutils-avr avr-libc stm32flash dfu-util libnewlib-arm-none-eabi gcc-arm-none-eabi binutils-arm-none-eabi libusb-1.0-0 libusb-1.0-0-dev pkg-config python3-numpy libatlas3-base libatlas-base-dev libgfortran5}"

RATOS_APT_DEPS="${RATOS_APT_DEPS:-python3-serial python3-opencv}"

MAINSAIL_APT_DEPS="${MAINSAIL_APT_DEPS:-nginx wget unzip git}"

TIMELAPSE_APT_DEPS="${TIMELAPSE_APT_DEPS:-ffmpeg}"

KLIPPERSCREEN_APT_DEPS="${KLIPPERSCREEN_APT_DEPS:-xserver-xorg-legacy}"

RPI_MCU_APT_DEPS="${RPI_MCU_APT_DEPS:-make}"

LATTEPANDA_IOTA_RP2040_APT_DEPS="${LATTEPANDA_IOTA_RP2040_APT_DEPS:-make libusb-1.0-0-dev}"
